# Root env for `docker compose up`. Copy to `.env` and fill in real values.
# Never commit `.env`. Backend's own `backend/.env.example` covers running the
# backend directly (outside Compose) against `localhost` services.

# Postgres container init (used only by the postgres image on first boot)
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=changeme
POSTGRES_DB=orchestrator

# Backend (values below already point at the in-network Compose service names;
# override only if you know what you're doing)
DATABASE_URL=postgresql://orchestrator:changeme@postgres:5432/orchestrator
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_EXPIRY_MINUTES=30
ENVIRONMENT=development

# Frontend (consumed by Vite; wired once PR3 adds the frontend service)
VITE_API_BASE_URL=http://localhost:8000

# Optional: allow the browser-hosted frontend to call this API cross-origin
# (e.g. `npm run dev` on :5173 talking to the dockerized backend on :8000).
# Comma-separated exact origins. Empty (default) = no CORS middleware at all.
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional: seed the first admin user on backend startup (idempotent —
# no-op once any admin exists). Useful for local/demo bring-up only.
# FIRST_ADMIN_EMAIL=admin@example.com
# FIRST_ADMIN_PASSWORD=change-me

# Optional: host's docker.sock GID, needed by the `worker` service to reach
# the Docker daemon as a non-root user. Find via:
#   stat -c '%g' /var/run/docker.sock   (Linux)
#   ls -la /var/run/docker.sock         (macOS, read the group column)
# DOCKER_GID=999
